{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mirror Agent",
  "version": "0.1.0",
  "identifier": "com.mirror.agent",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Mirror Agent",
        "width": 1200,
        "height": 820,
        "minWidth": 960,
        "minHeight": 680,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 16,
          "y": 18
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Mirror",
    "category": "Productivity",
    "shortDescription": "Mirror Agent desktop app",
    "longDescription": "A Tauri desktop shell for the Mirror Agent chat application."
  }
}
